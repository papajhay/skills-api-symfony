<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Symfony Baseline{% endblock %}</title>
        <style>
            :root {
                color-scheme: light;
                --bg: #f6f1e8;
                --panel: #fffaf3;
                --text: #1f2933;
                --muted: #5f6b76;
                --accent: #0f766e;
                --border: #d8d0c4;
            }

            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                font-family: Georgia, "Times New Roman", serif;
                background:
                    radial-gradient(circle at top left, rgba(15, 118, 110, 0.12), transparent 30%),
                    linear-gradient(180deg, #fffdf9 0%, var(--bg) 100%);
                color: var(--text);
            }

            .shell {
                max-width: 960px;
                margin: 0 auto;
                padding: 48px 24px 72px;
            }

            .panel {
                background: var(--panel);
                border: 1px solid var(--border);
                border-radius: 24px;
                padding: 32px;
                box-shadow: 0 24px 64px rgba(31, 41, 51, 0.08);
            }

            h1, h2, h3 {
                margin-top: 0;
                line-height: 1.1;
            }

            .eyebrow {
                color: var(--accent);
                text-transform: uppercase;
                letter-spacing: 0.12em;
                font-size: 0.78rem;
                font-weight: 700;
            }

            .muted {
                color: var(--muted);
            }

            code {
                background: rgba(15, 118, 110, 0.08);
                padding: 0.15rem 0.35rem;
                border-radius: 0.35rem;
            }
        </style>
    </head>
    <body>
        <main class="shell">
            {% block body %}{% endblock %}
        </main>
    </body>
</html>
